# =============================================================================
# platform_mobile - Variables para consumir service-users y service-platform
# =============================================================================
# Uso con react-native-config:
#   - Copiar a la raíz como .env:  cp env/.env_main .env
#   - O ejecutar con:  ENVFILE=env/.env_main npm run android  (y similar para ios)
# =============================================================================

# -----------------------------------------------------------------------------
# Service Users (auth, usuarios, verificación, contraseñas)
# -----------------------------------------------------------------------------
# Desarrollo: IP de tu máquina en la red local (puerto por defecto del servicio: 4000)
# Obtener IP: ./scripts/get-network-ip.sh  (o ifconfig / ipconfig)
API_BASE_URL_DEV=https://api.tutoke.app/users

# Producción: URL pública del API de usuarios
API_BASE_URL=https://api.tutoke.app/users

# -----------------------------------------------------------------------------
# Service Platform (rooms, Kinesis, URL HLS firmada)
# -----------------------------------------------------------------------------
# Desarrollo: misma IP que arriba, puerto de service-platform (por defecto: 8001)
PLATFORM_HTTP_URL_DEV=https://api.tutoke.app/platform

# Producción: URL pública de service-platform
PLATFORM_HTTP_URL=https://api.tutoke.app/platform

# -----------------------------------------------------------------------------
# Opcional: IP del servidor en desarrollo (alternativa a incluirla en API_BASE_URL_DEV)
# -----------------------------------------------------------------------------
# DEV_SERVER_IP=localhost
